# Syndication credentials for the auto-poster. Copy to `.env` (gitignored) and
# fill in. NEVER commit `.env`.

# --- Bluesky -----------------------------------------------------------------
# Use an APP PASSWORD, not your login password:
#   Settings → Privacy and Security → App Passwords → Add App Password
# Identifier can be your handle (e.g. readme.dm once live, or *.bsky.social) or
# your DID (did:plc:s2fkhpplh3qlqdrixlx3zvgd).
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=

# --- Mastodon (mathstodon) ---------------------------------------------------
# Access token from: mathstodon.xyz → Preferences → Development → New
# Application (scope: write:statuses). Copy "Your access token".
MASTODON_BASE_URL=https://mathstodon.xyz
MASTODON_ACCESS_TOKEN=
